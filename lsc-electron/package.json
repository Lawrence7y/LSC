{
  "name": "lsc-electron",
  "version": "1.0.0",
  "description": "LSC 直播切片系统 - Electron 版本",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron": "vite --config vite.config.ts",
    "electron:build": "tsc --noEmit && vite build && electron-builder"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.12.0",
    "dayjs": "^1.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^1.1.0"
  },
  "build": {
    "appId": "com.lsc.app",
    "productName": "LSC 直播切片系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron",
      "dist"
    ],
    "extraResources": [
      { "from": "../python-backend", "to": "python-backend" }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
